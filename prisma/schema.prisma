// HRMS Database Schema
// PostgreSQL via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  WEEKEND
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AuditAction {
  CHECK_IN
  CHECK_OUT
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PROFILE_UPDATE
  ADMIN_RULE_CHANGE
  SCHEDULE_UPDATE
  HOLIDAY_CREATE
  HOLIDAY_DELETE
  EMPLOYEE_CREATE
  EMPLOYEE_UPDATE
  EMPLOYEE_DELETE
  IP_SETTING_CHANGE
  GEOFENCE_CHANGE
  SALARY_RULE_CHANGE
  ATTENDANCE_OVERRIDE
  ANNOUNCEMENT_CREATE
  ANNOUNCEMENT_UPDATE
  ANNOUNCEMENT_DELETE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACT
}

// ─────────────────────────────────────────────
// USER / EMPLOYEE
// ─────────────────────────────────────────────

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  password          String?        // null for OAuth users
  role              UserRole       @default(EMPLOYEE)
  employmentType    EmploymentType @default(FULL_TIME)
  department        String?
  designation       String?
  phone             String?
  avatar            String?
  joiningDate       DateTime       @default(now())
  dateOfBirth       DateTime?      @db.Date
  isActive          Boolean        @default(true)
  timeFormat        String         @default("24h")

  // OAuth
  googleId          String?        @unique

  // Email verification
  emailVerified     DateTime?

  // Password reset
  resetToken        String?
  resetTokenExpiry  DateTime?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  attendanceRecords  AttendanceRecord[]
  customSchedule     EmployeeSchedule?
  companyScheduleId  String?
  companySchedule    CompanySchedule? @relation(fields: [companyScheduleId], references: [id], onDelete: SetNull)
  salaryRulesId      String?
  salaryRules        SalaryRules?     @relation(fields: [salaryRulesId], references: [id], onDelete: SetNull)
  salaryRuleOverride SalaryRuleOverride?
  sessions           Session[]
  auditLogs          AuditLog[]
  announcements      Announcement[]

  @@map("users")
}

// ─────────────────────────────────────────────
// SESSION (next-auth compatible)
// ─────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rememberMe   Boolean  @default(false)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// ATTENDANCE RECORD
// ─────────────────────────────────────────────

model AttendanceRecord {
  id                String           @id @default(cuid())
  userId            String
  date              DateTime         @db.Date  // just the date, no time

  // Server timestamps (NEVER from browser)
  checkInAt         DateTime?        // exact server time of check-in
  checkOutAt        DateTime?        // exact server time of check-out

  // Request metadata
  checkInIp         String?
  checkOutIp        String?
  checkInLat        Float?
  checkInLng        Float?
  checkOutLat       Float?
  checkOutLng       Float?

  // Validation
  checkInIpValid    Boolean?
  checkInGeoValid   Boolean?
  checkOutIpValid   Boolean?
  checkOutGeoValid  Boolean?

  // Computed status
  status            AttendanceStatus @default(PRESENT)
  isLate            Boolean          @default(false)
  isHalfDay         Boolean          @default(false)
  lateMinutes       Int              @default(0)

  // Admin override
  overriddenBy      String?
  overrideNote      String?
  overriddenAt      DateTime?

  // Audit
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])  // one record per employee per day
  @@map("attendance_records")
}

// ─────────────────────────────────────────────
// COMPANY SCHEDULE (default)
// ─────────────────────────────────────────────

model CompanySchedule {
  id                String   @id @default(cuid())
  name              String   @default("Default Schedule")
  isDefault         Boolean  @default(false)

  startTime         String   @default("11:00")  // HH:mm
  endTime           String   @default("20:00")
  lateAfter         String   @default("11:15")  // after this = LATE
  halfDayAfter      String   @default("14:00")  // after this = HALF_DAY

  // Working days (true = working)
  monday            Boolean  @default(true)
  tuesday           Boolean  @default(true)
  wednesday         Boolean  @default(true)
  thursday          Boolean  @default(true)
  friday            Boolean  @default(true)
  saturday          Boolean  @default(false)
  sunday            Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]

  @@map("company_schedules")
}

// ─────────────────────────────────────────────
// EMPLOYEE-SPECIFIC SCHEDULE OVERRIDE
// ─────────────────────────────────────────────

model EmployeeSchedule {
  id                String   @id @default(cuid())
  userId            String   @unique

  startTime         String
  endTime           String
  lateAfter         String
  halfDayAfter      String

  monday            Boolean  @default(true)
  tuesday           Boolean  @default(true)
  wednesday         Boolean  @default(true)
  thursday          Boolean  @default(true)
  friday            Boolean  @default(true)
  saturday          Boolean  @default(false)
  sunday            Boolean  @default(false)

  note              String?  // e.g. "Intern schedule"

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_schedules")
}

// ─────────────────────────────────────────────
// HOLIDAYS
// ─────────────────────────────────────────────

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @db.Date
  isOptional  Boolean  @default(false)  // optional leave vs mandatory holiday

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
  @@map("holidays")
}

// ─────────────────────────────────────────────
// OFFICE SETTINGS (Geofence + IP)
// ─────────────────────────────────────────────

model OfficeSettings {
  id              String   @id @default(cuid())
  name            String   @default("Main Office")
  timezone        String   @default("Asia/Kolkata")

  // Geofence
  latitude        Float    @default(0)
  longitude       Float    @default(0)
  radiusMeters    Float    @default(200)
  geofenceEnabled Boolean  @default(true)

  // IP allowlist (stored as JSON array of strings)
  allowedIps      Json     @default("[]")   // ["192.168.1.0/24", "203.0.113.5"]
  ipCheckEnabled  Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("office_settings")
}

// ─────────────────────────────────────────────
// ATTENDANCE RULES
// ─────────────────────────────────────────────

model AttendanceRules {
  id                         String   @id @default(cuid())

  // Late streak penalty
  lateStreakDays             Int      @default(3)    // consecutive late days before penalty
  lateStreakPenalty          String   @default("HALF_DAY")  // "HALF_DAY" | "WARNING" | "NONE"

  // Grace period before absent
  graceMinutes               Int      @default(0)

  // Auto-mark absent if no check-in by this time (24h format "HH:mm")
  autoAbsentAfter            String   @default("15:00")

  // Minimum hours for full day
  minHoursFullDay            Float    @default(8.0)
  minHoursHalfDay            Float    @default(4.0)

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@map("attendance_rules")
}

// ─────────────────────────────────────────────
// SALARY RULES
// ─────────────────────────────────────────────

model SalaryRules {
  id                      String   @id @default(cuid())
  name                    String   @default("Default Salary Rule")
  isDefault               Boolean  @default(false)

  // Default Base Salary
  baseSalary              Float    @default(0)

  // Formula: baseSalary * (daysWorked / payableWorkingDays)
  // Deductions for late / half day
  halfDayDeductionFactor  Float    @default(0.5)   // half day = 0.5 day deducted
  lateDeductionPerDay     Float    @default(0)     // optional per-late-day deduction
  absentDeductionFactor   Float    @default(1.0)   // absent = 1 day deducted

  // Paid leave days per month
  paidLeaveDaysPerMonth   Int      @default(1)

  note                    String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                   User[]

  @@map("salary_rules")
}

// ─────────────────────────────────────────────
// PER-EMPLOYEE SALARY OVERRIDE
// ─────────────────────────────────────────────

model SalaryRuleOverride {
  id                      String   @id @default(cuid())
  userId                  String   @unique

  baseSalary              Float?
  halfDayDeductionFactor  Float?
  absentDeductionFactor   Float?
  paidLeaveDaysPerMonth   Int?
  customFormula           String?  // future: expression string
  note                    String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("salary_rule_overrides")
}

// ─────────────────────────────────────────────
// LEAVE REQUESTS (scaffold for future)
// ─────────────────────────────────────────────

model LeaveRequest {
  id          String   @id @default(cuid())
  userId      String
  fromDate    DateTime @db.Date
  toDate      DateTime @db.Date
  reason      String?
  status      String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  approvedBy  String?
  approvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("leave_requests")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  description String
  metadata    Json?       // arbitrary extra data
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────

model Announcement {
  id                 String    @id @default(cuid())
  title              String
  content            String
  isActive           Boolean   @default(true)

  // Calendar reflection
  reflectOnCalendar  Boolean   @default(false)
  eventDate          DateTime? @db.Date
  eventName          String?

  createdById        String?
  createdBy          User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("announcements")
}

// ─────────────────────────────────────────────
// INBOX ITEMS (approval scaffold for future phases)
// ─────────────────────────────────────────────

model InboxItem {
  id          String   @id @default(cuid())
  type        String   // e.g. "LEAVE_REQUEST", "ONBOARDING", "OTHER"
  title       String
  description String?
  status      String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  relatedId   String?  // foreign key to related entity (future use)
  metadata    Json?    // extra data for the item

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inbox_items")
}
